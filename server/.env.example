# ─────────────────────────────────────────────────────────────
# MeetScribe Server — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000

# Gemini API (get from https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Recall.ai (get from https://www.recall.ai)
RECALL_API_KEY=your_recall_api_key_here

# Firebase Admin SDK
# Download the service account JSON from Firebase Console →
# Project Settings → Service Accounts → Generate New Private Key
# Then set the path to that file:
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# GCP Cloud Storage (for storing transcripts/summaries)
GCS_BUCKET_NAME=your-meetscribe-bucket
