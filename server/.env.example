# ─────────────────────────────────────────────────────────────
# MeetScribe Server — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Server
PORT=5001

# Frontend origin for CORS (your Vercel URL in production)
CLIENT_URL=http://localhost:3000

# Gemini API (get from https://aistudio.google.com)
# Used for summarization, embeddings (RAG), and the Ask feature.
GEMINI_API_KEY=your_gemini_api_key_here

# Recall.ai (get from https://www.recall.ai)
RECALL_API_KEY=your_recall_api_key_here
RECALL_REGION=us-west-2

# Firebase Admin SDK — two options:
#
# Local dev: download the service account JSON from Firebase Console →
# Project Settings → Service Accounts → Generate New Private Key,
# drop it in server/, and point to it here:
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
#
# Cloud (e.g. Render): paste the whole JSON as a single-line string instead:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
